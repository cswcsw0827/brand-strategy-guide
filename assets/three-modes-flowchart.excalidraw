    {
      "id": "e-bg",
      "type": "rectangle",
      "x": 120,
      "y": 1573,
      "width": 960,
      "height": 150,
      "backgroundColor": "#ffffff",
      "strokeColor": "#dee2e6",
      "strokeWidth": 2,
      "roughness": 0,
