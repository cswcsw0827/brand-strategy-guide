      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
      "roughness": 0,
      "text": "📖  品牌故事三段式：初心 → 态度 → 承诺",
      "fontSize": 20,
      "fontFamily": 2,
      "createdAt": "2026-06-13T07:49:44.801Z",
