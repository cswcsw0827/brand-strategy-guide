    },
    {
      "id": "cta-t1",
      "type": "text",
      "x": 600,
      "y": 1748,
      "width": 800,
      "height": 26,
      "strokeColor": "#ffffff",
      "strokeWidth": 2,
      "roughness": 0,
      "text": "📱 现在打开备忘录，写下第一句话：",
      "fontSize": 18,
      "fontFamily": 2,
      "createdAt": "2026-06-13T07:49:44.830Z",
      "updatedAt": "2026-06-13T07:49:44.830Z",
      "version": 1
    },
    {
      "id": "cta-t2",
      "type": "text",
      "x": 600,
      "y": 1778,
      "width": 800,
      "height": 22,
      "strokeColor": "#dee2e6",
      "strokeWidth": 2,
      "roughness": 0,
      "text": "\"我做这件事，不是因为看到了市场机会，而是因为 ______。\"",
