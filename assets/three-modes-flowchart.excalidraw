    {
      "id": "h-bar",
      "type": "rectangle",
      "x": 120,
      "y": 144,
      "width": 4,
      "height": 112,
      "backgroundColor": "#1e1e1e",
      "strokeColor": "#1e1e1e",
      "strokeWidth": 2,
      "roughness": 0,
      "fontSize": 20,
      "fontFamily": 5,
